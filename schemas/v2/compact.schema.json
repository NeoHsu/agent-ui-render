{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-ui/v2/compact.schema.json",
  "title": "CompactReportInputV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": { "const": 2 },
    "t": { "type": "string" },
    "s": { "type": "string" },
    "theme": { "enum": ["report-light", "technical-dark", "executive-clean"] },
    "density": { "enum": ["comfortable", "compact"] },
    "emphasis": { "enum": ["strong", "subtle"] },
    "dict": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" } }
    },
    "d": { "type": "array", "items": { "$ref": "#/$defs/dataset" } },
    "m": { "type": "array", "items": { "$ref": "#/$defs/metric" } },
    "v": { "type": "array", "items": { "$ref": "#/$defs/view" } },
    "a": { "type": "array", "items": { "$ref": "#/$defs/alert" } },
    "md": { "type": "array", "items": { "$ref": "#/$defs/markdownSection" } },
    "i": { "type": "array", "items": { "type": "string" } },
    "as": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "primitive": { "type": ["string", "number", "boolean", "null"] },
    "typeCode": {
      "anyOf": [
        { "enum": ["s", "n", "cur", "pct", "d", "dt", "b"] },
        { "type": "string", "pattern": "^dict:[a-z][a-z0-9]*(?:_[a-z0-9]+)*$" }
      ]
    },
    "column": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/typeCode" },
        { "type": "string" },
        { "type": "string" }
      ]
    },
    "rowMajorDataset": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/column" } },
        { "type": "array", "items": { "type": "array", "items": { "$ref": "#/$defs/primitive" } } }
      ]
    },
    "columnMajorDataset": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "const": "cols" },
        { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/column" } },
        { "type": "array", "items": { "type": "array", "items": { "$ref": "#/$defs/primitive" } } }
      ]
    },
    "refDataset": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "const": "ref" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "dataset": {
      "oneOf": [
        { "$ref": "#/$defs/rowMajorDataset" },
        { "$ref": "#/$defs/columnMajorDataset" },
        { "$ref": "#/$defs/refDataset" }
      ]
    },
    "metric": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "$ref": "#/$defs/primitive" },
        { "anyOf": [{ "$ref": "#/$defs/typeCode" }, { "type": "null" }] },
        { "type": ["string", "null"] },
        { "$ref": "#/$defs/metricDelta" }
      ]
    },
    "metricDelta": {
      "oneOf": [
        { "type": ["number", "null"] },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "prefixItems": [
            { "type": "number" },
            { "enum": ["n", "pct"] }
          ]
        }
      ]
    },
    "datasetIndex": { "type": "integer", "minimum": 0 },
    "columnIndex": { "type": "integer", "minimum": 0 },
    "columnIndexes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/columnIndex" }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "t": { "type": "string" },
        "or": { "enum": ["h", "v"] },
        "st": { "enum": ["none", "zero", "normalize", "center"] },
        "ag": { "enum": ["sum", "mean", "median", "min", "max", "count"] },
        "bn": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "integer", "minimum": 1 } }
          ]
        },
        "ip": { "enum": ["linear", "monotone", "step", "step-before", "step-after"] },
        "mode": { "enum": ["slope", "bump", "stream", "horizon", "diverging", "strip", "rug", "pyramid"] },
        "pt": { "type": "boolean" },
        "lb": { "type": "boolean" },
        "lg": { "type": "boolean" },
        "tip": { "type": "boolean" },
        "sort": { "enum": ["asc", "desc", "none"] },
        "top": { "type": "integer", "minimum": 1 },
        "zero": { "type": "boolean" },
        "shape": { "enum": ["circle", "square", "tick"] },
        "jitter": { "type": "boolean" },
        "sel": { "enum": ["none", "hover", "click", "brush", "zoom", "legend"] },
        "resolve": { "enum": ["shared", "independent"] }
      }
    },
    "legacyView": {
      "oneOf": [
        {
          "type": "array", "minItems": 2, "maxItems": 2,
          "prefixItems": [{ "enum": ["o", "r"] }, { "$ref": "#/$defs/datasetIndex" }]
        },
        {
          "type": "array", "minItems": 4, "maxItems": 4,
          "prefixItems": [
            { "enum": ["t", "b", "p", "s"] },
            { "$ref": "#/$defs/datasetIndex" },
            { "$ref": "#/$defs/columnIndex" },
            { "$ref": "#/$defs/columnIndexes" }
          ]
        },
        {
          "type": "array", "minItems": 3, "maxItems": 4,
          "prefixItems": [
            { "const": "d" },
            { "$ref": "#/$defs/datasetIndex" },
            { "$ref": "#/$defs/columnIndex" },
            { "$ref": "#/$defs/columnIndexes" }
          ]
        },
        {
          "type": "array", "minItems": 3, "maxItems": 3,
          "prefixItems": [
            { "const": "r" },
            { "$ref": "#/$defs/datasetIndex" },
            { "$ref": "#/$defs/columnIndexes" }
          ]
        }
      ]
    },
    "chartCode": {
      "enum": [
        "ln", "ar", "tr", "reg", "bar", "gantt", "water", "bullet", "range",
        "hist", "den", "dot", "box", "box5", "qq", "sc", "par", "tri", "heat",
        "mos", "pie", "don", "rad", "err", "band", "candle", "text", "tick", "rule"
      ]
    },
    "chartValue": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string" },
        { "type": "null" },
        { "$ref": "#/$defs/columnIndexes" },
        { "$ref": "#/$defs/options" }
      ]
    },
    "chartView": {
      "type": "array",
      "minItems": 3,
      "maxItems": 9,
      "prefixItems": [{ "$ref": "#/$defs/chartCode" }, { "$ref": "#/$defs/datasetIndex" }],
      "items": { "$ref": "#/$defs/chartValue" }
    },
    "layerView": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "prefixItems": [
        { "const": "layer" },
        { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/chartView" } },
        { "$ref": "#/$defs/options" }
      ]
    },
    "facetView": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "prefixItems": [
        { "const": "facet" },
        { "$ref": "#/$defs/chartView" },
        { "oneOf": [{ "$ref": "#/$defs/columnIndex" }, { "type": "null" }] },
        { "oneOf": [{ "$ref": "#/$defs/columnIndex" }, { "type": "null" }, { "$ref": "#/$defs/options" }] },
        { "$ref": "#/$defs/options" }
      ]
    },
    "concatView": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "prefixItems": [
        { "const": "concat" },
        { "enum": ["h", "v"] },
        { "type": "array", "minItems": 1, "items": { "oneOf": [{ "$ref": "#/$defs/chartView" }, { "$ref": "#/$defs/layerView" }] } },
        { "$ref": "#/$defs/options" }
      ]
    },
    "repeatView": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "prefixItems": [
        { "const": "repeat" },
        { "$ref": "#/$defs/chartView" },
        { "$ref": "#/$defs/columnIndexes" },
        { "enum": ["h", "v", "grid"] },
        { "$ref": "#/$defs/options" }
      ]
    },
    "view": {
      "oneOf": [
        { "$ref": "#/$defs/legacyView" },
        { "$ref": "#/$defs/chartView" },
        { "$ref": "#/$defs/layerView" },
        { "$ref": "#/$defs/facetView" },
        { "$ref": "#/$defs/concatView" },
        { "$ref": "#/$defs/repeatView" }
      ]
    },
    "alert": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "prefixItems": [
        { "enum": ["i", "s", "w", "e", "c"] },
        { "type": "string", "minLength": 1 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "markdownSection": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "type": "string", "minLength": 1 }
      ]
    }
  }
}
